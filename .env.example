# Required: path to the SQLite database file (will be created on first run)
POKEMON_DB_PATH=/naspool/appdata/pokemonprofessor/db/pokemon.sqlite

# Optional: HTTP listen port (default: 8000)
PORT=8000

# Optional: ZeroClaw LLM gateway URL — leave blank to disable AI coach
ZEROCLAW_GATEWAY=

# Optional: ZeroClaw agent profile name
ZEROCLAW_AGENT=pokemonprofessor
