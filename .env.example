# Required: path to the SQLite database file (will be created on first run)
POKEMON_DB_PATH=/data/pokemonprofessor/db/pokemon.sqlite

# Optional: HTTP listen port (default: 8000)
PORT=8000

# Optional: Ollama base URL — leave blank to disable AI coach
COACH_HOST=http://localhost:11434

# Optional: Ollama model to use for coaching responses
COACH_MODEL=qwen2.5:3b

# Optional: Custom system prompt for the AI coach (leave blank for default)
COACH_SYSTEM_PROMPT=
